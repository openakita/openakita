## 验证脚本

创建 `test_api_connections.py` 验证连通性：

```python
import os
import requests
from dotenv import load_dotenv

load_dotenv('mvp/api-integration/.env.credentials')

def test_wechat():
    """测试企业微信"""
    corp_id = os.getenv('WECHAT_CORP_ID')
    agent_id = os.getenv('WECHAT_AGENT_ID')
    secret = os.getenv('WECHAT_SECRET')
    
    if not all([corp_id, agent_id, secret]):
        print("❌ 企业微信：配置不完整")
        return False
    
    # 获取 Access Token
    url = f"https://qyapi.weixin.qq.com/cgi-bin/gettoken?corpid={corp_id}&corpsecret={secret}"
    resp = requests.get(url)
    if resp.json().get('errcode') == 0:
        print("✅ 企业微信：连接成功")
        return True
    else:
        print(f"❌ 企业微信：连接失败 - {resp.json()}")
        return False

def test_dingtalk():
    """测试钉钉"""
    app_key = os.getenv('DINGTALK_APP_KEY')
    app_secret = os.getenv('DINGTALK_APP_SECRET')
    
    if not all([app_key, app_secret]):
        print("❌ 钉钉：配置不完整")
        return False
    
    # 获取 Access Token
    url = f"https://oapi.dingtalk.com/gettoken?appkey={app_key}&appsecret={app_secret}"
    resp = requests.get(url)
    if resp.json().get('errcode') == 0:
        print("✅ 钉钉：连接成功")
        return True
    else:
        print(f"❌ 钉钉：连接失败 - {resp.json()}")
        return False

def test_feishu():
    """测试飞书"""
    app_id = os.getenv('FEISHU_APP_ID')
    app_secret = os.getenv('FEISHU_APP_SECRET')
    
    if not all([app_id, app_secret]):
        print("❌ 飞书：配置不完整")
        return False
    
    # 获取 Access Token
    url = "https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal"
    payload = {"app_id": app_id, "app_secret": app_secret}
    resp = requests.post(url, json=payload)
    if resp.json().get('code') == 0:
        print("✅ 飞书：连接成功")
        return True
    else:
        print(f"❌ 飞书：连接失败 - {resp.json()}")
        return False

if __name__ == '__main__':
    print("=" * 50)
    print("MVP API 连接性测试")
    print("=" * 50)
    
    results = []
    results.append(test_wechat())
    results.append(test_dingtalk())
    results.append(test_feishu())
    
    print("=" * 50)
    if all(results):
        print("🎉 所有 API 连接成功！")
    else:
        print(f"⚠️  {results.count(False)} 个 API 连接失败，请检查配置")
```

