# MVP API 集成 - 环境变量配置模板
# 复制此文件为 .env 并填入真实凭据
# ⚠️ .env 文件不应提交到 Git 仓库

# ============================================
# 阿里云服务 (邮件推送 + 短信 + OSS)
# ============================================
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_REGION_ID=cn-hangzhou

# 邮件推送
ALIYUN_MAIL_ACCOUNT=your_mail_account
ALIYUN_MAIL_FROM=notifications@yourdomain.com

# 短信服务
ALIYUN_SMS_SIGN_NAME=你的签名名称
ALIYUN_SMS_TEMPLATE_CODE=your_template_code

# 对象存储 OSS
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET_NAME=your-bucket-name

# ============================================
# 企业微信 (消息通知)
# ============================================
WECHAT_CORP_ID=your_corp_id
WECHAT_AGENT_ID=your_agent_id
WECHAT_AGENT_SECRET=your_agent_secret

# ============================================
# 钉钉 (备选消息通知)
# ============================================
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
DINGTALK_AGENT_ID=your_agent_id

# ============================================
# 飞书 (多维表格 + 消息)
# ============================================
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_BITABLE_APP_TOKEN=your_app_token

# ============================================
# Google Calendar (日程同步)
# ============================================
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_CALENDAR_ID=primary

# ============================================
# CRM 系统 (销售易/纷享销客)
# ============================================
CRM_API_BASE_URL=https://api.crm-provider.com
CRM_CLIENT_ID=your_client_id
CRM_CLIENT_SECRET=your_client_secret
CRM_ACCESS_TOKEN=your_access_token

# ============================================
# PostgreSQL 数据库 (含 pgvector)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/mvp_db
PGVECTOR_DIMENSION=1536

# ============================================
# 通用配置
# ============================================
# API 模式：mock | real
API_MODE=mock

# 日志级别：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 重试配置
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=2
