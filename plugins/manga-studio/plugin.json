{
  "id": "manga-studio",
  "name": "Manga Studio",
  "version": "1.0.0",
  "type": "python",
  "entry": "plugin.py",
  "description": "AI manga drama studio — story to script to panels to animated video with character consistency, supporting both direct Seedance API and ComfyUI/RunningHub workflow backends.",
  "display_name_zh": "漫剧工作室",
  "display_name_en": "Manga Studio",
  "description_i18n": {
    "zh": "AI 漫剧工作室 — 故事 → 剧本 → 分镜 → 漫画动画视频，自带角色卡与剧集管理；支持直接 Seedance 和 ComfyUI 工作流双后端。",
    "en": "AI manga drama studio — story → script → panels → animated video, with character cards and series management; supports both direct Seedance and ComfyUI workflows."
  },
  "icon": "icon.svg",
  "author": "OpenAkita",
  "category": "creative",
  "tags": ["manga", "anime", "video", "storyboard", "ai", "drama"],
  "permissions": [
    "tools.register",
    "routes.register",
    "hooks.basic",
    "config.read",
    "config.write",
    "data.own",
    "brain.access"
  ],
  "requires": {
    "openakita": ">=1.27.0",
    "plugin_api": "~2",
    "plugin_ui_api": "~1",
    "sdk": ">=0.7.0,<0.8.0"
  },
  "provides": {
    "tools": [
      "manga_create_series",
      "manga_create_episode",
      "manga_episode_status",
      "manga_list_episodes",
      "manga_create_character",
      "manga_list_characters",
      "manga_quick_drama",
      "manga_split_script",
      "manga_render_panel",
      "manga_cost_preview",
      "manga_workflow_test"
    ],
    "routes": true
  },
  "ui": {
    "entry": "ui/dist/index.html",
    "icon": "icon.svg",
    "title": "漫剧工作室",
    "title_i18n": {
      "en": "Manga Studio",
      "zh": "漫剧工作室"
    },
    "sidebar_group": "apps",
    "permissions": ["upload", "download", "notifications", "theme", "clipboard"]
  }
}
