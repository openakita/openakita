{
  "id": "manga-studio",
  "name": "Manga Studio",
  "version": "1.0.0",
  "type": "python",
  "entry": "plugin.py",
  "description": "AI manga drama studio with character cards, series management and direct/ComfyUI/RunningHub backends.",
  "display_name_zh": "漫剧工作室",
  "display_name_en": "Manga Studio",
  "description_i18n": {
    "zh": "AI 漫剧工作室，自带角色卡与剧集管理，支持 Seedance 直连、ComfyUI 与 RunningHub 工作流多后端出片。",
    "en": "AI manga drama studio with character cards, series management and direct/ComfyUI/RunningHub backends."
  },
  "icon": "icon.svg",
  "author": "OpenAkita",
  "category": "creative",
  "tags": ["manga", "anime", "video", "storyboard", "ai", "drama"],
  "permissions": [
    "tools.register",
    "routes.register",
    "hooks.basic",
    "config.read",
    "config.write",
    "data.own",
    "brain.access"
  ],
  "requires": {
    "openakita": ">=1.27.0",
    "plugin_api": "~2",
    "plugin_ui_api": "~1",
    "sdk": ">=0.7.0,<0.8.0"
  },
  "provides": {
    "tools": [
      "manga_create_series",
      "manga_create_episode",
      "manga_episode_status",
      "manga_list_episodes",
      "manga_create_character",
      "manga_list_characters",
      "manga_quick_drama",
      "manga_split_script",
      "manga_render_panel",
      "manga_cost_preview",
      "manga_workflow_test"
    ],
    "routes": true
  },
  "tool_classes": {
    "manga_create_series": "network_out",
    "manga_create_episode": "network_out",
    "manga_episode_status": "readonly_scoped",
    "manga_list_episodes": "readonly_scoped",
    "manga_create_character": "network_out",
    "manga_list_characters": "readonly_scoped",
    "manga_quick_drama": "network_out",
    "manga_split_script": "network_out",
    "manga_render_panel": "network_out",
    "manga_cost_preview": "readonly_scoped",
    "manga_workflow_test": "network_out"
  },
  "ui": {
    "entry": "ui/dist/index.html",
    "icon": "icon.svg",
    "title": "漫剧工作室",
    "title_i18n": {
      "en": "Manga Studio",
      "zh": "漫剧工作室"
    },
    "sidebar_group": "apps",
    "permissions": ["upload", "download", "notifications", "theme", "clipboard"]
  }
}
