# =====================================================
# OpenAkita - 生产环境配置模板
# 版本：v1.0
# 最后更新：2026-03-14
# =====================================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 修改以下配置项（必填项已标注）
# 3. 运行：docker-compose -f docker-compose.prod.yml up -d
# =====================================================

# ── 应用配置 ─────────────────────────────────────────────

# Docker 镜像名称（可自定义）
APP_IMAGE=openakita/app:latest

# API 服务端口
APP_PORT=8000

# 应用资源限制
APP_CPU_LIMIT=2.0
APP_MEMORY_LIMIT=2G
APP_CPU_RESERVE=1.0
APP_MEMORY_RESERVE=1G

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# ── 数据库配置 (PostgreSQL) ─────────────────────────────

# 数据库用户
POSTGRES_USER=postgres

# 数据库密码 [必填 - 请修改为强密码]
POSTGRES_PASSWORD=change_this_password_in_production

# 数据库名称
POSTGRES_DB=openakita

# 数据库端口
POSTGRES_PORT=5432

# 数据库资源限制
POSTGRES_CPU_LIMIT=2.0
POSTGRES_MEMORY_LIMIT=2G

# ── Redis 配置 ───────────────────────────────────────────

# Redis 密码 [必填 - 请修改为强密码]
REDIS_PASSWORD=change_this_redis_password_in_production

# Redis 端口
REDIS_PORT=6379

# Redis 资源限制
REDIS_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=1G

# ── Qdrant 向量数据库配置 ────────────────────────────────

# Qdrant HTTP API 端口
QDRANT_PORT=6333

# Qdrant gRPC 端口
QDRANT_GRPC_PORT=6334

# Qdrant API Key (可选，增强安全性)
QDRANT_API_KEY=

# Qdrant 资源限制
QDRANT_CPU_LIMIT=2.0
QDRANT_MEMORY_LIMIT=4G

# ── LLM API 配置 [必填 - 至少配置一个] ───────────────────

# Anthropic Claude API Key [推荐]
# 获取地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# OpenAI API Key [备用]
# 获取地址：https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-api-key-here

# 默认 LLM 提供商 (anthropic/openai/azure)
DEFAULT_LLM_PROVIDER=anthropic

# ── 安全配置 ─────────────────────────────────────────────

# 应用密钥 [必填 - 生成方法：openssl rand -hex 32]
SECRET_KEY=change_this_to_a_random_secret_key_in_production

# JWT Token 过期时间（小时）
JWT_EXPIRY_HOURS=24

# 允许的 CORS 源（逗号分隔，生产环境请指定具体域名）
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── 功能开关 ─────────────────────────────────────────────

# MCP (Model Context Protocol) 支持
MCP_ENABLED=true

# 多 Agent 协同模式
MULTI_AGENT_ENABLED=true

# 浏览器自动化功能
BROWSER_ENABLED=true

# 网络搜索功能
WEB_SEARCH_ENABLED=true

# ── Celery 异步任务配置 ──────────────────────────────────

# Worker 并发数
CELERY_CONCURRENCY=2

# Worker 资源限制
CELERY_CPU_LIMIT=2.0
CELERY_MEMORY_LIMIT=2G

# 任务超时时间（秒）
CELERY_TASK_TIMEOUT=300

# ── 监控配置 (可选) ──────────────────────────────────────

# Prometheus 端口
PROMETHEUS_PORT=9090

# Grafana 端口
GRAFANA_PORT=3000

# Grafana 管理员账号 [必填 - 请修改]
GRAFANA_ADMIN_USER=admin

# Grafana 管理员密码 [必填 - 请修改]
GRAFANA_ADMIN_PASSWORD=admin123

# Loki 日志端口
LOKI_PORT=3100

# ── Nginx 反向代理配置 (可选) ───────────────────────────

# Nginx HTTP 端口
NGINX_HTTP_PORT=80

# Nginx HTTPS 端口
NGINX_HTTPS_PORT=443

# 域名（用于 HTTPS 证书）
DOMAIN_NAME=your-domain.com

# SSL 证书路径（相对于项目根目录）
SSL_CERTIFICATE_PATH=./monitoring/ssl/fullchain.pem
SSL_KEY_PATH=./monitoring/ssl/privkey.pem

# ── 备份配置 ─────────────────────────────────────────────

# 备份目录
BACKUP_DIR=./backups

# 自动备份保留天数
BACKUP_RETENTION_DAYS=30

# ── 其他配置 ─────────────────────────────────────────────

# 时区
TZ=Asia/Shanghai

# 是否启用调试模式（生产环境请设为 false）
DEBUG=false

# 允许的主机（逗号分隔）
ALLOWED_HOSTS=localhost,127.0.0.1

# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE_MB=100

# 会话过期时间（分钟）
SESSION_TIMEOUT_MINUTES=1440

# ── 邮件配置 (可选，用于通知) ───────────────────────────

# SMTP 服务器
SMTP_HOST=smtp.gmail.com

# SMTP 端口
SMTP_PORT=587

# SMTP 用户
SMTP_USER=

# SMTP 密码
SMTP_PASSWORD=

# 发件人邮箱
FROM_EMAIL=

# 是否启用 TLS
SMTP_USE_TLS=true

# ── 存储配置 (可选，对象存储) ───────────────────────────

# 存储类型 (local/s3/oss/cos)
STORAGE_TYPE=local

# S3 配置（当 STORAGE_TYPE=s3 时）
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# ── 高级配置 (一般不需要修改) ───────────────────────────

# 数据库连接池大小
DATABASE_POOL_SIZE=10

# 数据库最大连接数
DATABASE_MAX_OVERFLOW=20

# Redis 连接池大小
REDIS_POOL_SIZE=10

# Qdrant 超时时间（秒）
QDRANT_TIMEOUT=30

# HTTP 请求超时时间（秒）
HTTP_REQUEST_TIMEOUT=60

# 重试次数
MAX_RETRIES=3

# 重试延迟（秒）
RETRY_DELAY=1

# =====================================================
# 配置完成检查清单
# =====================================================
# [ ] POSTGRES_PASSWORD 已修改为强密码
# [ ] REDIS_PASSWORD 已修改为强密码
# [ ] SECRET_KEY 已生成随机值
# [ ] ANTHROPIC_API_KEY 或 OPENAI_API_KEY 已配置
# [ ] GRAFANA_ADMIN_PASSWORD 已修改为强密码
# [ ] DEBUG=false (生产环境)
# [ ] CORS_ORIGINS 已配置为实际域名
# =====================================================
