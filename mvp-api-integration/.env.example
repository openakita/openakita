# OpenAkita MVP API 集成示例

# JWT 认证
JWT_SECRET_KEY=your-secret-key-change-in-production

# 支付宝
ALIPAY_APP_ID=your_app_id
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key

# 阿里云
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=OpenAkita
SMS_TEMPLATE_CODE=SMS_123456789
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=your-bucket-name

# 测试手机号
TEST_PHONE_NUMBER=13800138000

# SMTP 邮件
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
TEST_EMAIL=test@example.com

# 高德地图
AMAP_API_KEY=your-amap-api-key

# 微信
WECHAT_APP_ID=your-app-id
WECHAT_APP_SECRET=your-app-secret
WECHAT_REDIRECT_URI=https://your-domain.com/callback

# 企业微信
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# 钉钉
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token
DINGTALK_SECRET=your-secret

# GitHub
GITHUB_TOKEN=your-github-token
GITHUB_REPO_OWNER=openakita
GITHUB_REPO_NAME=openakita
